{
  "name": "institutionsguide",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-sitemap.mjs && node scripts/generate-seo-data.mjs && node scripts/build-postnummer-index.mjs",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/prerender-articles.mjs && node scripts/prerender-pages.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "assessments": "node scripts/batch-assessments.mjs",
    "assessments:dry": "node scripts/batch-assessments.mjs --dry-run",
    "kommune-summaries": "node scripts/generate-kommune-summaries.mjs",
    "kommune-summaries:dry": "node scripts/generate-kommune-summaries.mjs --dry-run",
    "fetch:inst-stats": "node scripts/fetch-institution-stats.mjs",
    "fetch:kommune-stats": "node scripts/fetch-dst-kommune-stats.mjs",
    "fetch:arbejdstilsyn": "node scripts/fetch-arbejdstilsyn.mjs",
    "fetch:all-data": "npm run fetch:inst-stats && npm run fetch:kommune-stats",
    "fetch:satisfaction": "node scripts/fetch-foraeldre-tilfredshed.mjs",
    "refresh": "npm run fetch:kommune-stats && node scripts/build-normering-data.mjs && npm run fetch:satisfaction && node scripts/generate-sitemap.mjs",
    "refresh:all": "node scripts/refresh-all.mjs",
    "refresh:all:dry": "node scripts/refresh-all.mjs --dry-run",
    "tilsyn:scrape": "node scripts/tilsyn/scrape-kommune.mjs --all",
    "tilsyn:scrape:kommune": "node scripts/tilsyn/scrape-kommune.mjs --kommune",
    "fetch:tilsynsrapporter": "node scripts/fetch-tilsynsrapporter.mjs",
    "fetch:tilsynsrapporter:dry": "node scripts/fetch-tilsynsrapporter.mjs --dry-run",
    "seo:indexnow": "node scripts/submit-indexnow.mjs",
    "seo:ping": "node scripts/ping-search-engines.mjs",
    "seo:submit": "npm run seo:ping && npm run seo:indexnow",
    "generate:rss": "node scripts/generate-rss.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.46.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@vercel/analytics": "^2.0.1",
    "dompurify": "^3.3.3",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^1.7.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/edge": "^1.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
